{
  "name": "qwen_lora_fake_smoke",
  "description": "Tiny smoke (5 step, fake data) to verify HF + peft LoRA pipeline works end-to-end.",
  "model_name": "./Qwen2.5-1.5B-Instruct",
  "system_prompt": "你是信息抽取助手。",
  "lora": {
    "r": 8,
    "alpha": 16,
    "targets": ["q_proj", "k_proj", "v_proj", "o_proj"],
    "dropout": 0.05
  },
  "optimizer": {
    "lr": 3e-5,
    "weight_decay": 0.01
  },
  "training": {
    "batch_size": 2,
    "gradient_accumulation_steps": 2,
    "max_steps": 5,
    "eval_interval": 5,
    "save_interval": 5,
    "warmup_steps": 1,
    "max_grad_norm": 1.0,
    "max_length": 256,
    "device": "cuda",
    "seed": 42,
    "out_dir": "outputs/qwen_lora_fake_smoke",
    "fp16": true
  },
  "data": {
    "train_data_path": "data/sft_smoke_fake/train.jsonl",
    "valid_data_path": "data/sft_smoke_fake/valid.jsonl"
  },
  "logging": {
    "wandb_project": "micro-llm-qwen",
    "run_name": "qwen_lora_fake_smoke",
    "mode": "disabled"
  }
}
